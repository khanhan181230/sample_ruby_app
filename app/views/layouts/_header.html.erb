<header class="navbar navbar-expand-md navbar-dark bg-custom-header fixed-top">
  <div class="container">
    <%= link_to "sample app", root_path, id: "logo", class: "navbar-brand"%>
    <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar" aria-controls="navbar" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon "></span>
    </button>
    <nav class="collapse navbar-collapse justify-content-end" id="navbar">
      <ul class="navbar-nav"> 
        <li class="nav-item ms-3"><%= link_to "Home", root_path, class: "nav-link"%></li>
        <li class="nav-item ms-3"><%= link_to "Help", help_path, class: "nav-link"%></li>
        <% if logged_in? %>
          <li class="nav-item ms-3"><%= link_to "Users", users_path, class: "nav-link"%></li>
          <li class="nav-item ms-3 dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              Account
            </a>
            <ul class="dropdown-menu">
              <li><%= link_to "Profile", current_user, class: "dropdown-item" %></li>
              <li><%= link_to "Settings", edit_user_path(current_user), class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
            </ul>
          </li>
        <% else %>
          <li class="nav-item ms-3"><%= link_to "Login", login_path, class: "nav-link"%></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
